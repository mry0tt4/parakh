# Copy to .env and adjust. All settings have safe dev defaults.
PARAKH_ENVIRONMENT=dev
PARAKH_JWT_SECRET=change-me-to-a-long-random-string-32bytes-min
PARAKH_JWT_EXPIRES_SECONDS=3600
PARAKH_DATABASE_URL=sqlite:///./parakh.db
# PARAKH_DATABASE_URL=postgresql+psycopg://user:pass@host:5432/parakh
PARAKH_CORS_ORIGINS=["http://localhost:5173"]
PARAKH_RATE_LIMIT_PER_MINUTE=240
PARAKH_LOGIN_RATE_LIMIT_PER_MINUTE=10
PARAKH_OFFICER_DECISION_LIMIT=2500000
PARAKH_AUTOSEED=true
